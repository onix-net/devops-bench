{
  "$comment": "SAMPLE PROFILE (Antigravity / agy) — full eval/infra workflow: running evals on the bastion (run-eval, validate-eval, run-parallel-evals). Merge the permissions block into ~/.gemini/antigravity-cli/settings.json. Targets are RE2 regexes matched against the whole command line (use .* for args; no look-ahead). Precedence: deny > ask > allow. Unlisted: workspace files auto-allowed; read_url/execute_url/command/mcp default to ask. See README.md.",
  "permissions": {
    "allow": [
      "command(ls( .*)?)",
      "command(cat( .*)?)",
      "command(head( .*)?)",
      "command(tail( .*)?)",
      "command(grep( .*)?)",
      "command(rg( .*)?)",
      "command(find( .*)?)",
      "command(jq( .*)?)",
      "command(yq( .*)?)",
      "command(sed( .*)?)",
      "command(awk( .*)?)",
      "command(echo( .*)?)",
      "command(which( .*)?)",
      "command(pwd)",
      "command(env)",
      "command(date)",
      "command(make( .*)?)",
      "command(git( .*)?)",
      "command(uv( .*)?)",
      "command(uvx( .*)?)",
      "command((python|python3)( .*)?)",
      "command(pytest( .*)?)",
      "command(ruff( .*)?)",
      "command(ssh( .*)?)",
      "command(scp( .*)?)",
      "command(rsync( .*)?)",
      "command(gcloud( .*)?)",
      "command(gsutil( .*)?)",
      "command(kubectl( .*)?)",
      "command((terraform|tofu)( .*)?)",
      "command(kind( .*)?)",
      "command(docker( .*)?)",
      "command((bash|sh) .*)",
      "command(scripts/.*)",
      "command(rm -rf /tmp/devops-bench-runs.*)",
      "command(rm -rf .*/matrix-runs/.*)",
      "command(kind delete cluster( .*)?)",
      "read_url(.*)",
      "mcp(gke-mcp/.*)"
    ],
    "ask": [
      "command(git push( .*)?)",
      "command((terraform|tofu) apply( .*)?)",
      "command((terraform|tofu) destroy( .*)?)",
      "command(kubectl delete( .*)?)",
      "command(gcloud .* delete( .*)?)",
      "command(docker system prune( .*)?)",
      "execute_url(.*)"
    ],
    "deny": [
      "command(sudo( .*)?)",
      "command(doas( .*)?)",
      "command(rm -rf /( .*)?)",
      "command(rm -fr /( .*)?)",
      "command(rm -rf /\\*( .*)?)",
      "command(rm -rf ~( .*)?)",
      "command(rm -rf \\$HOME( .*)?)",
      "command(.*(curl|wget).*\\|.*(ba)?sh.*)",
      "command(gcloud projects delete( .*)?)",
      "command(gcloud organizations .*)",
      "command(git push .*(--force|-f|\\+[a-zA-Z]).*)",
      "read_file(.*\\.ssh/id_.*)",
      "read_file(.*(id_rsa|id_ed25519|id_ecdsa).*)",
      "write_file(.*\\.git/.*)"
    ]
  }
}
