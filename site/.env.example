# =============================================================================
# Environment config (Vite). Config is layered by mode, NOT hardcoded in source.
# A Firebase web API key is PUBLIC (access is enforced by Firestore Security
# Rules), so the committed files below are safe to ship.
#
# Files (Vite loads them in this precedence order, highest first):
#   .env.<mode>.local   ─ gitignored, per-mode personal override
#   .env.local          ─ gitignored, all-mode personal override
#   .env.<mode>         ─ committed, per-mode target  (development/staging/production)
#   .env                ─ committed, shared Firebase project config
#
# Targets (one named Firestore database per environment, all in ONE project):
#   npm run dev            → mode development → emulator      → DB leaderboard-test
#   npm run dev:staging    → mode staging     → real Firestore → DB leaderboard-test
#   npm run build:staging  → mode staging     → real Firestore → DB leaderboard-test
#   npm run build          → mode production   → real Firestore → DB leaderboard   (prod)
# =============================================================================

# --- .env (shared project config) -------------------------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- per-mode (set in .env.development / .env.staging / .env.production) ------
# Named Firestore database id. Empty/unset → the (default) database.
VITE_FIRESTORE_DATABASE_ID=
# "true" forces the emulator, "false" forces real Firestore. Unset → emulator in
# dev (`vite`), real Firestore in build/preview.
VITE_USE_EMULATOR=
